# ═══════════════════════════════════════════════════════════
# Trading Bot — ملف إعدادات البيئة
# ═══════════════════════════════════════════════════════════
# نسخ هذا الملف:   cp .env.example .env
# ثم ملء البيانات:  nano .env  أو  notepad .env
#
# ⚠️  لا ترفع ملف .env أبداً إلى GitHub أو أي مكان عام!
#     ملف .gitignore يحميه بالفعل.
# ═══════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────
# 1️⃣  وضع التداول (TRADING_MODE)
# ─────────────────────────────────────────────────────────
#
# paper  → تداول ورقي آمن 100% (موصى به في جميع مراحل التطوير)
#           - بيانات حقيقية من بينانس
#           - أوامر محاكاة محلية (لا أموال حقيقية)
#           - لا يحتاج API Keys
#
# live   → تداول حقيقي (فقط بعد اجتياز جميع اختبارات paper)
#           - يحتاج BINANCE_API_KEY و BINANCE_SECRET_KEY
#           - يُنفّذ أوامر حقيقية بأموال حقيقية!
#
# ⛔  testnet متوقف (Binance Futures Testnet deprecated في CCXT يونيو 2025)

TRADING_MODE=paper


# ─────────────────────────────────────────────────────────
# 2️⃣  إعدادات Paper Trading
# ─────────────────────────────────────────────────────────
# الرصيد الوهمي الأولي بالـ USDT (لوضع paper فقط)
# غيّره لأي رقم تريد للتجربة

PAPER_INITIAL_BALANCE=10000.0


# ─────────────────────────────────────────────────────────
# 3️⃣  مفاتيح بينانس (للإنتاج فقط — TRADING_MODE=live)
# ─────────────────────────────────────────────────────────
# الحصول عليها: https://www.binance.com/en/account/api-management
#
# تحقق من الصلاحيات:
#   ✅ Futures Trading  — مطلوب
#   ✅ Read Info        — مطلوب
#   ❌ Withdraw         — اتركه معطلاً (أمان)

BINANCE_API_KEY=
BINANCE_SECRET_KEY=


# ─────────────────────────────────────────────────────────
# 4️⃣  Telegram Bot (للتنبيهات — سيُضاف لاحقاً)
# ─────────────────────────────────────────────────────────
# الحصول على Token: ابحث عن @BotFather في تيليجرام
# الحصول على Chat ID: ابحث عن @userinfobot

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here


# ─────────────────────────────────────────────────────────
# 5️⃣  إعدادات متقدمة (اختيارية)
# ─────────────────────────────────────────────────────────

# مستوى السجلات: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# وضع التصحيح (يُطبع معلومات إضافية)
DEBUG_MODE=false
